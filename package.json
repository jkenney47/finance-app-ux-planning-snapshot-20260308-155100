{
  "name": "ai-financial-advisor",
  "version": "0.1.0",
  "private": true,
  "main": "expo-router/entry",
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "bootstrap": "bash scripts/bootstrap.sh",
    "lint:app": "eslint \"app/**/*.{ts,tsx,js,jsx}\" \"components/**/*.{ts,tsx,js,jsx}\" \"utils/**/*.{ts,tsx,js,jsx}\" \"stores/**/*.{ts,tsx,js,jsx}\" \"hooks/**/*.{ts,tsx,js,jsx}\" \"theme/**/*.{ts,tsx,js,jsx}\" \"__tests__/**/*.{ts,tsx,js,jsx}\" --cache",
    "lint:app:fix": "eslint \"app/**/*.{ts,tsx,js,jsx}\" \"components/**/*.{ts,tsx,js,jsx}\" \"utils/**/*.{ts,tsx,js,jsx}\" \"stores/**/*.{ts,tsx,js,jsx}\" \"hooks/**/*.{ts,tsx,js,jsx}\" \"theme/**/*.{ts,tsx,js,jsx}\" \"__tests__/**/*.{ts,tsx,js,jsx}\" --cache --fix",
    "lint:supabase": "eslint \"supabase/functions/**/*.{ts,tsx}\" --cache",
    "lint:supabase:fix": "eslint \"supabase/functions/**/*.{ts,tsx}\" --cache --fix",
    "lint:scripts": "eslint \"scripts/**/*.{js,mjs,cjs}\" --cache",
    "lint:scripts:fix": "eslint \"scripts/**/*.{js,mjs,cjs}\" --cache --fix",
    "lint": "npm run lint:app && npm run lint:supabase && npm run lint:scripts",
    "lint:fix": "npm run lint:app:fix && npm run lint:supabase:fix && npm run lint:scripts:fix",
    "lint:design-tokens": "node scripts/lint-design-tokens.mjs",
    "lint:staged": "lint-staged",
    "prepare": "husky",
    "dev:client": "expo start --dev-client",
    "build:dev:ios": "eas build --profile development --platform ios",
    "start": "expo start --dev-client",
    "validate:env": "node scripts/validate-env.mjs",
    "validate:system-map": "node scripts/validate-system-map.mjs",
    "validate:tracked-secrets": "node scripts/scan-tracked-secrets.mjs",
    "validate:case-collisions": "node scripts/validate-case-collisions.mjs",
    "validate:maestro-flows": "node scripts/validate-maestro-flows.mjs",
    "security:audit:summary": "node scripts/dependency-security-audit.mjs",
    "schema:generate": "node scripts/schema-sync.mjs generate",
    "schema:check": "node scripts/schema-sync.mjs check",
    "branch:retention:report": "node scripts/branch-retention.mjs",
    "branch:retention:apply": "node scripts/branch-retention.mjs --apply",
    "memory:start": "bash .agents/hooks/codex-autopilot.sh start",
    "memory:run": "bash .agents/hooks/codex-autopilot.sh run",
    "memory:add": "bash .agents/hooks/codex-autopilot.sh add",
    "memory:checkpoint": "bash .agents/hooks/codex-autopilot.sh checkpoint",
    "check:instruction-drift": "bash scripts/check-instruction-drift.sh",
    "typecheck:app": "tsc --noEmit -p tsconfig.json",
    "typecheck:supabase": "tsc --noEmit -p tsconfig.supabase.json",
    "typecheck:scripts": "tsc --noEmit -p tsconfig.scripts.json",
    "typecheck": "npm run typecheck:app && npm run typecheck:supabase && npm run typecheck:scripts",
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "depgraph:build": "node scripts/generate-dependency-graph.mjs",
    "depgraph:check:app": "madge --extensions ts,tsx --ts-config tsconfig.json --circular app components hooks stores theme utils",
    "depgraph:check:backend": "madge --extensions ts --ts-config tsconfig.supabase.json --circular supabase/functions && madge --extensions js,mjs,cjs --circular scripts",
    "depgraph:check": "npm run depgraph:check:app && npm run depgraph:check:backend",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "validate": "npm run validate:env && npm run validate:tracked-secrets && npm run validate:system-map && npm run validate:case-collisions && npm run schema:check && npm run typecheck && npm run lint && npm run format:check && npm run validate:maestro-flows && npm run depgraph:check && npm run test:coverage && npm run memory:checkpoint",
    "e2e": "bash scripts/e2e.sh",
    "ux:loop": "bash scripts/ux-loop.sh",
    "ux:loop:all": "bash scripts/ux-loop.sh --all",
    "rollout:phase-a": "node scripts/milestone-6-phase-a-check.mjs",
    "rollout:ingestion": "node scripts/milestone-6-ingestion-check.mjs",
    "supabase:gen:types": "node scripts/generate-supabase-types.mjs",
    "test:agent-sandbox": "bash scripts/test-agent-sandbox.sh",
    "smoke:ios": "bash scripts/smoke-ios.sh",
    "xcode:stabilize": "bash scripts/xcode-stabilize-connection.sh",
    "gemini:collab:help": "bash scripts/gemini-collab.sh help",
    "gemini:collab:plan": "bash scripts/gemini-collab.sh plan",
    "gemini:collab:diff": "bash scripts/gemini-collab.sh diff",
    "gemini:collab:diff-gate": "bash scripts/gemini-collab.sh diff-gate",
    "gemini:collab:screenshot": "bash scripts/gemini-collab.sh screenshot",
    "gemini:collab:screenshot-gate": "bash scripts/gemini-collab.sh screenshot-gate",
    "gemini:collab:triage": "bash scripts/gemini-collab.sh triage",
    "ui:review": "bash scripts/ui-review.sh",
    "skills:eval": "node scripts/skills-eval.mjs --fixtures tests/skills/fixtures/invocation-regression.ndjson --top-k 3 --write docs/reports/skills-invocation-latest.md --json docs/reports/skills-invocation-latest.json",
    "agent:ops:report": "node .agents/skills/agent-ops-optimizer/scripts/analyze-agent-ops.mjs --days 14 --write docs/reports/agent-ops-latest.md --json docs/reports/agent-ops-latest.json",
    "plan:review": "bash scripts/plan-review.sh",
    "plan:auto-review": "bash scripts/auto-plan-review.sh",
    "plan:guard": "bash scripts/check-plan-review.sh",
    "plan:finalize": "bash scripts/plan-finalize.sh",
    "plan:implementation:guard": "bash scripts/check-plan-gate.sh",
    "plan:implementation:guard:all": "bash scripts/check-plan-gate.sh --all",
    "figma:api:check": "node scripts/figma-api-check.mjs",
    "storybook": "storybook dev -p 6006 --disable-telemetry",
    "ios": "LANG=en_US.UTF-8 LC_ALL=en_US.UTF-8 expo run:ios",
    "story": "storybook dev -p 6006 --disable-telemetry"
  },
  "dependencies": {
    "@babel/runtime": "^7.27.6",
    "@expo/metro-runtime": "~55.0.6",
    "@hookform/resolvers": "^5.2.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-picker/picker": "2.11.4",
    "@react-navigation/native": "^7.1.6",
    "@rn-primitives/portal": "^1.3.0",
    "@rn-primitives/separator": "^1.2.0",
    "@rn-primitives/slot": "^1.2.0",
    "@sentry/react-native": "^8.2.0",
    "@supabase/supabase-js": "^2.75.0",
    "@tanstack/react-query": "^5.83.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "expo": "^55.0.0",
    "expo-application": "~55.0.8",
    "expo-constants": "~55.0.7",
    "expo-dev-client": "~55.0.10",
    "expo-device": "~55.0.9",
    "expo-font": "~55.0.4",
    "expo-glass-effect": "~55.0.7",
    "expo-haptics": "~55.0.8",
    "expo-linking": "~55.0.7",
    "expo-router": "~55.0.3",
    "expo-status-bar": "~55.0.4",
    "expo-updates": "~55.0.12",
    "lucide-react-native": "^0.522.0",
    "nativewind": "^4.2.2",
    "phosphor-react-native": "^2.3.1",
    "posthog-react-native": "^4.36.1",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-hook-form": "^7.71.2",
    "react-native": "0.83.2",
    "react-native-circular-progress": "^1.4.1",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-picker-select": "^9.3.1",
    "react-native-purchases": "^9.10.5",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "15.15.3",
    "react-native-vector-icons": "^10.2.0",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "0.7.2",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^3.4.19",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^3.25.76",
    "zustand": "^5.0.6"
  },
  "devDependencies": {
    "@babel/core": "^7.28.0",
    "@babel/plugin-transform-runtime": "^7.28.0",
    "@babel/preset-flow": "^7.27.1",
    "@babel/preset-typescript": "^7.27.1",
    "@expo/config": "^55.0.7",
    "@react-native-community/cli-server-api": "^18.0.1",
    "@react-native/metro-config": "^0.74.89",
    "@rnx-kit/metro-resolver-symlinks": "^0.1.22",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/react-native": "^13.2.0",
    "@types/jest": "^29.5.12",
    "@types/react": "~19.2.10",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "babel-jest": "^29.7.0",
    "babel-plugin-module-resolver": "^5.0.2",
    "babel-plugin-transform-flow-strip-types": "^6.22.0",
    "babel-preset-expo": "~55.0.8",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-react": "^7.34.1",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-native": "^5.0.0",
    "eslint-plugin-testing-library": "^6.2.0",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "jest-expo": "~55.0.9",
    "lint-staged": "^16.1.2",
    "madge": "^8.0.0",
    "metro": "^0.83.1",
    "metro-transform-worker": "^0.76.0",
    "patch-package": "^8.0.0",
    "postinstall-postinstall": "^2.1.0",
    "prettier": "^3.6.2",
    "ts-jest": "^29.1.2",
    "typescript": "~5.9.2"
  }
}

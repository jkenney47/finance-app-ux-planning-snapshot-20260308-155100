# Finance App environment variables
# Copy to .env and fill in values.

# Client app
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
EXPO_PUBLIC_SUPABASE_FUNCTIONS_BASE_URL=
EXPO_PUBLIC_SENTRY_DSN=
# Optional analytics (PostHog) – session replay is disabled by app config.
EXPO_PUBLIC_POSTHOG_API_KEY=
EXPO_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
EXPO_PUBLIC_REVENUECAT_IOS_API_KEY=
EXPO_PUBLIC_REVENUECAT_ANDROID_API_KEY=
EXPO_PUBLIC_USE_MOCK_DATA=true
EXPO_PUBLIC_MOCK_SCENARIO=default
# Live Plaid sandbox linking requires both flags below set to true.
EXPO_PUBLIC_ENABLE_PLAID_SANDBOX_LINK=false
EXPO_PUBLIC_ENABLE_REAL_ACCOUNT_DATA=false
EXPO_PUBLIC_BYPASS_AUTH=false
EXPO_PUBLIC_ENABLE_REMOTE_POLICY_PACKS=false
EXPO_PUBLIC_ENABLE_REMOTE_RULE_PACKS=false
EXPO_PUBLIC_COMPLIANCE_MODE=education
EXPO_PUBLIC_ENABLE_AGENT_EXPLANATIONS=false
EXPO_PUBLIC_ENABLE_POLICY_INGESTION_AGENT=false
EXPO_PUBLIC_FME_EXPLAIN_PROVIDER_KEY=mock_agent_bridge
EXPO_PUBLIC_POLICY_INGEST_PROVIDER_KEY=mock_agent_bridge

# Supabase functions/secrets
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY
PLAID_CLIENT_ID=YOUR_PLAID_CLIENT_ID
PLAID_SECRET=YOUR_PLAID_SECRET
PLAID_ENV=sandbox
PLAID_COUNTRY_CODES=US
PLAID_PRODUCTS=transactions
PLAID_SANDBOX_INSTITUTION_ID=ins_109508
# Optional: webhook endpoint your Plaid sandbox item should post to.
PLAID_WEBHOOK_URL=
PLAID_VERIFICATION_CODE=YOUR_PLAID_VERIFICATION_CODE
POLICY_REFRESH_SECRET=YOUR_POLICY_REFRESH_SECRET
FME_LOG_SIGNING_SECRET=YOUR_FME_LOG_SIGNING_SECRET
POLICY_OPS_SIGNING_SECRET=YOUR_POLICY_OPS_SIGNING_SECRET
# Comma-separated Supabase user IDs allowed to run policy mutation actions.
POLICY_OPS_ADMIN_USER_IDS=YOUR_ADMIN_USER_ID

# Agent gateway (third-party interop)
# Comma-separated host allowlist for outbound provider calls (required for non-dry-run).
AGENT_GATEWAY_ALLOWED_HOSTS=api.openai.com,api.anthropic.com
# Example provider secret keys (referenced by provider metadata in agent_providers):
# OPENAI_PROVIDER_API_KEY=YOUR_OPENAI_PROVIDER_API_KEY
# ANTHROPIC_PROVIDER_API_KEY=YOUR_ANTHROPIC_PROVIDER_API_KEY

# Optional local development flags
# MOCK_PLAID is not readable by the Expo client; use EXPO_PUBLIC_USE_MOCK_DATA instead.

# Gemini collaboration tooling (optional local CLI review)
GEMINI_API_KEY=
# Optional aliases (if you prefer existing Google variable names):
# GOOGLE_GENAI_API_KEY=
# GOOGLE_API_KEY=

# Figma MCP + API (optional, local tooling only)
# For direct REST API calls, FIGMA_ACCESS_TOKEN is preferred.
FIGMA_ACCESS_TOKEN=
# MCP auth in Codex often uses this variable name.
FIGMA_OAUTH_TOKEN=
# Optional region header for MCP/API calls where needed.
FIGMA_REGION=us-east-1
# Optional override; defaults to https://api.figma.com in scripts.
FIGMA_API_BASE_URL=https://api.figma.com

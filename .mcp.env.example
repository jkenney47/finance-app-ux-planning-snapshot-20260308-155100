# MCP token/config template
# Copy values from your account dashboards, then apply them to mcp.config.json placeholders.

# Figma MCP + API
# Use this variable name in Codex "Bearer token env var" for remote Figma MCP.
FIGMA_OAUTH_TOKEN=figma_oauth_token_here
# Optional if a client expects a generic token variable name.
MCP_BEARER_TOKEN=figma_oauth_token_here
# Optional region header value when required by client configuration.
X_FIGMA_REGION=us-east-1
# Optional direct Figma REST API token (preferred for /v1 endpoints).
FIGMA_ACCESS_TOKEN=figma_access_token_here

# Context7 MCP (optional; unlocks higher request limits)
CONTEXT7_API_KEY=ctx7sk_your_context7_key_here

# GitHub MCP
GITHUB_PAT=ghp_your_token_here
GITHUB_PERSONAL_ACCESS_TOKEN=ghp_your_token_here

# Supabase MCP
SUPABASE_PROJECT_REF=your_project_ref

# Sentry MCP
SENTRY_ACCESS_TOKEN=your_sentry_token
EMBEDDED_AGENT_PROVIDER=openai

# LLM provider for Sentry MCP embedded agent tools
OPENAI_API_KEY=sk-your-openai-key

# Gemini CLI (plan/diff/screenshot review automation)
GEMINI_API_KEY=your_gemini_api_key

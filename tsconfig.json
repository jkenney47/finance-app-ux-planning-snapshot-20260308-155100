{
  "compilerOptions": {
    "strict": true,
    "allowImportingTsExtensions": true,
    "baseUrl": ".",
    "jsx": "react-jsx",
    "paths": {
      "@/*": ["./*"],
      "@/app/*": ["app/*"],
      "@/components/*": ["components/*"],
      "@/utils/*": ["utils/*"],
      "@/types/*": ["types/*"],
      "@/stores/*": ["stores/*"],
      "@/hooks/*": ["hooks/*"],
      "@/theme/*": ["theme/*"],
      "@test-utils": ["__tests__/utils/test-utils"]
    }
  },
  "include": [
    "app",
    "components",
    "utils",
    "types",
    "stores",
    "hooks",
    "theme",
    "__tests__",
    "nativewind-env.d.ts"
  ],
  "exclude": ["node_modules"],
  "extends": "expo/tsconfig.base"
}
